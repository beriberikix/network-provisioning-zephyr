# Network provisioning manager (Wi-Fi over BLE) for Zephyr
#
# SPDX-License-Identifier: Apache-2.0

config NETWORK_PROV_CORE
	bool "Network provisioning protocol core (protocomm + security schemes)"
	depends on NANOPB
	depends on MBEDTLS
	help
	  Transport-agnostic protocomm engine, the protobuf wire format and the
	  security schemes 0/1. Has no Bluetooth, Wi-Fi or storage dependencies,
	  so it also builds on native_sim — this is what the unit tests enable.
	  Selected automatically by NETWORK_PROV_MGR.

config NETWORK_PROV_BLE
	bool "BLE transport (protocomm over GATT)"
	depends on NETWORK_PROV_CORE
	depends on BT_PERIPHERAL && BT_GATT_DYNAMIC_DB
	help
	  Carry the provisioning protocol over BLE GATT — what the stock
	  "ESP BLE Provisioning" apps speak.

config NETWORK_PROV_SOFTAP
	bool "SoftAP transport (protocomm over HTTP)"
	depends on NETWORK_PROV_CORE
	depends on HTTP_SERVER
	# HTTP_SERVER builds without TCP but its listener then fails at runtime
	# with EPROTOTYPE, so require TCP explicitly.
	depends on NET_TCP
	# Session continuity relies on reading the client's Cookie header;
	# without header capture every request would reset the session and
	# the security-1 handshake could never complete.
	depends on HTTP_SERVER_CAPTURE_HEADERS
	help
	  Carry the provisioning protocol over HTTP POST on a device-hosted
	  access point at 192.168.4.1 — what the stock "ESP SoftAP
	  Provisioning" apps speak. The AP itself additionally needs Wi-Fi
	  AP+STA mode and a DHCPv4 server; see the wifi_prov_softap sample's
	  prj.conf.

menuconfig NETWORK_PROV_MGR
	bool "Network provisioning manager (Wi-Fi provisioning)"
	# Depend on (rather than select) heavy subsystems: selecting symbols that
	# carry their own dependencies (Wi-Fi, storage) triggers Kconfig
	# recursive-dependency errors. The application enables these — and one of
	# the transports above — see the samples' prj.conf files.
	depends on WIFI && WIFI_CREDENTIALS
	depends on MBEDTLS
	depends on SETTINGS
	depends on NANOPB
	select NETWORK_PROV_CORE
	select EXPERIMENTAL
	help
	  Espressif-compatible network provisioning service. Lets the stock ESP
	  provisioning apps (Android/iOS) configure the device's Wi-Fi
	  credentials over a secure protocomm session carried on BLE GATT
	  (NETWORK_PROV_BLE) or HTTP over a device-hosted access point
	  (NETWORK_PROV_SOFTAP). Enable at least one transport.

	  Wi-Fi credentials are stored through the native wifi_credentials
	  subsystem. Requires PSA Crypto (mbedTLS) for security scheme 1.

if NETWORK_PROV_MGR

config NETWORK_PROV_SCAN_MAX_ENTRIES
	int "Maximum number of Wi-Fi scan entries cached"
	default 16
	help
	  Upper bound on access points retained from a scan and offered to the
	  app (which retrieves them in pages via prov-scan).

config NETWORK_PROV_BLE_MAX_RESP_LEN
	int "Maximum protocomm response length (bytes) per endpoint"
	default 512
	help
	  Size of the per-characteristic response buffer. Must be large enough
	  for the biggest encoded (and encrypted) response, dominated by a page
	  of scan results.

config NETWORK_PROV_AUTOSTOP_TIMEOUT_MS
	int "Auto-stop grace period after a successful connection (ms)"
	default 30000
	help
	  After credentials succeed, the manager waits this long before
	  automatically tearing down the provisioning service, giving the
	  client time to read the final status (the apps keep polling
	  GetWifiStatus over the transport). Applications that manage teardown
	  themselves can opt out at runtime with
	  network_prov_mgr_disable_auto_stop().

endif # NETWORK_PROV_MGR

if NETWORK_PROV_CORE

module = NETWORK_PROV
module-str = network provisioning
source "subsys/logging/Kconfig.template.log_config"

endif # NETWORK_PROV_CORE

# Test-only simulated Wi-Fi backend (never enabled by the real samples).
rsource "sim/wifi/Kconfig"
